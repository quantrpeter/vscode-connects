{
  "name": "vscode-connects",
  "displayName": "VSCode Connects",
  "description": "An SSH client for VSCode: manage hosts in the sidebar, open SSH sessions as editor tabs, and sync hosts across machines.",
  "version": "0.0.11",
	"publisher": "hongkongprogrammingsociety",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:vscodeConnect.hosts"
  ],
	"repository": {
		"type": "git",
		"url": "https://github.com/quantrpeter/vscode-connects"
	},
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --external:cpu-features --external:*.node --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "npm run compile -- --minify",
    "package": "vsce package"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscodeConnect",
          "title": "VSCode Connect",
          "icon": "resources/connect.svg"
        }
      ]
    },
    "views": {
      "vscodeConnect": [
        {
          "type": "webview",
          "id": "vscodeConnect.hosts",
          "name": "SSH Hosts",
          "icon": "resources/connect.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "vscodeConnect.addHost",
        "title": "Add Host",
        "category": "VSCode Connect",
        "icon": "$(add)"
      },
      {
        "command": "vscodeConnect.editHost",
        "title": "Edit Host",
        "category": "VSCode Connect",
        "icon": "$(edit)"
      },
      {
        "command": "vscodeConnect.deleteHost",
        "title": "Delete Host",
        "category": "VSCode Connect",
        "icon": "$(trash)"
      },
      {
        "command": "vscodeConnect.connect",
        "title": "Connect",
        "category": "VSCode Connect",
        "icon": "$(plug)"
      },
      {
        "command": "vscodeConnect.search",
        "title": "Search Hosts",
        "category": "VSCode Connect",
        "icon": "$(search)"
      },
      {
        "command": "vscodeConnect.clearSearch",
        "title": "Clear Host Search",
        "category": "VSCode Connect",
        "icon": "$(clear-all)"
      },
      {
        "command": "vscodeConnect.exportConfig",
        "title": "Export Config",
        "category": "VSCode Connect",
        "icon": "$(save-as)"
      },
      {
        "command": "vscodeConnect.importConfig",
        "title": "Import Config",
        "category": "VSCode Connect",
        "icon": "$(repo-pull)"
      },
      {
        "command": "vscodeConnect.openSftpExplorer",
        "title": "Open SFTP Explorer",
        "category": "VSCode Connect",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscodeConnect.addHost",
          "when": "view == vscodeConnect.hosts",
          "group": "navigation@1"
        },
        {
          "command": "vscodeConnect.search",
          "when": "view == vscodeConnect.hosts",
          "group": "navigation@2"
        },
        {
          "command": "vscodeConnect.clearSearch",
          "when": "view == vscodeConnect.hosts && vscodeConnect.filtered",
          "group": "navigation@3"
        },
        {
          "command": "vscodeConnect.exportConfig",
          "when": "view == vscodeConnect.hosts",
          "group": "navigation@10"
        },
        {
          "command": "vscodeConnect.importConfig",
          "when": "view == vscodeConnect.hosts",
          "group": "navigation@11"
        }
      ],
      "commandPalette": [
        {
          "command": "vscodeConnect.editHost",
          "when": "false"
        },
        {
          "command": "vscodeConnect.deleteHost",
          "when": "false"
        },
        {
          "command": "vscodeConnect.connect",
          "when": "false"
        },
        {
          "command": "vscodeConnect.openSftpExplorer",
          "when": "false"
        }
      ]
    }
  },
  "dependencies": {
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ssh2": "^1.15.1",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
